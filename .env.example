# YouTube API Settings
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=your_channel_id_here

# YouTube Analytics API (OAuth) - Optional for Phase 2, Required for Phase 3
YOUTUBE_OAUTH_CLIENT_ID=your_client_id_here
YOUTUBE_OAUTH_CLIENT_SECRET=your_client_secret_here
YOUTUBE_OAUTH_REFRESH_TOKEN=your_refresh_token_here


# Google Cloud / BigQuery Settings
GCP_PROJECT_ID=your_project_id_here
GCP_DATASET_ID=your_dataset_id_here
# Path to service account key file for local development
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account-key.json

# Gemini API Settings
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: gemini-3.5-flash (default), gemini-3-flash, gemini-2.5-flash, etc.
GEMINI_MODEL=gemini-3.5-flash



# Slack Settings
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
